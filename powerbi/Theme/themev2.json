{
  "name": "Retail Dark Theme v2",
  "dataColors": [
    "#1F77B4",
    "#FF7F0E",
    "#9467BD",
    "#D62728",
    "#17BECF",
    "#2CA02C",
    "#8C564B",
    "#E377C2",
    "#7F7F7F",
    "#BCBD22"
  ],
  "background": "#0B1020",
  "foreground": "#F5F7FA",
  "tableAccent": "#1F77B4",

  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 13,
            "color": { "solid": { "color": "#F5F7FA" } }
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#141A33" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },

    "card": {
      "*": {
        "title": [
          {
            "show": true,
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "color": { "solid": { "color": "#AEB6FF" } }
          }
        ],
        "dataLabel": [
          {
            "fontFamily": "Segoe UI Bold",
            "fontSize": 20,
            "color": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "background": [
          {
            "show": true,
            "color": { "solid": { "color": "#1B2340" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },

    "clusteredBarChart": {
      "*": {
        "categoryAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#D0D4E6" } }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#D0D4E6" } },
            "gridlineColor": { "solid": { "color": "#28324D" } }
          }
        ]
      }
    },

    "lineChart": {
      "*": {
        "categoryAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#D0D4E6" } }
          }
        ],
        "valueAxis": [
          {
            "show": true,
            "labelColor": { "solid": { "color": "#D0D4E6" } },
            "gridlineColor": { "solid": { "color": "#28324D" } }
          }
        ]
      }
    },

    "matrix": {
      "*": {
        "grid": [
          {
            "gridlineColor": { "solid": { "color": "#28324D" } },
            "gridlineWeight": 1
          }
        ],
        "columnHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12,
            "color": { "solid": { "color": "#FFFFFF" } },
            "backgroundColor": { "solid": { "color": "#1B2340" } }
          }
        ],
        "rowHeaders": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 11,
            "color": { "solid": { "color": "#D0D4E6" } },
            "backgroundColor": { "solid": { "color": "#141A33" } }
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 11,
            "color": { "solid": { "color": "#FFFFFF" } },
            "backgroundColor": { "solid": { "color": "#141A33" } }
          }
        ]
      }
    },

    "table": {
      "*": {
        "grid": [
          {
            "gridlineColor": { "solid": { "color": "#28324D" } },
            "gridlineWeight": 1
          }
        ],
        "columnHeaders": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 12,
            "color": { "solid": { "color": "#FFFFFF" } },
            "backgroundColor": { "solid": { "color": "#1B2340" } }
          }
        ],
        "values": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 11,
            "color": { "solid": { "color": "#FFFFFF" } },
            "backgroundColor": { "solid": { "color": "#141A33" } }
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "header": [
          {
            "fontFamily": "Segoe UI Semibold",
            "fontSize": 11,
            "color": { "solid": { "color": "#FFFFFF" } },
            "background": { "solid": { "color": "#1B2340" } }
          }
        ],
        "items": [
          {
            "fontFamily": "Segoe UI",
            "fontSize": 10,
            "color": { "solid": { "color": "#D0D4E6" } },
            "background": { "solid": { "color": "#0B1020" } }
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    }
  }
}
