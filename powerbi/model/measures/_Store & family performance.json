-----------------------------
-- Measure: [Store Avg Sales]
-----------------------------
MEASURE _Measures[Store Avg Sales] = AVERAGE(dashboard_dataset[store_avg_sales])
    , DisplayFolder = "_Worst store / family"

-------------------------
-- Measure: [Worst Store]
-------------------------
MEASURE _Measures[Worst Store] = 
    VAR StoreErrors =
        ADDCOLUMNS(
            SUMMARIZE(dashboard_dataset, dashboard_dataset[store_nbr]),
            "Error", CALCULATE(AVERAGE(dashboard_dataset[residual]))
        )
    VAR Worst =
        TOPN(1, StoreErrors, [Error], DESC)
    RETURN
        MAXX(Worst, dashboard_dataset[store_nbr])
    , DisplayFolder = "_Worst store / family"
    , FormatString = "0"

