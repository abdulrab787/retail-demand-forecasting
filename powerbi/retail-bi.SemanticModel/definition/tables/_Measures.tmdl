table _Measures
	lineageTag: e48823e3-a53e-4f5f-be20-564ed1475500

	measure 'Total Revenue' = SUM(dashboard_dataset[actual])
		formatString: 0
		displayFolder: _KPI
		lineageTag: 9eb7dae4-c91c-4043-8377-cd8b3e7696d5

	measure 'Forecast Accuracy' =
			
			1 -
			DIVIDE(
			SUMX(dashboard_dataset, ABS(dashboard_dataset[residual])),
			SUM(dashboard_dataset[actual])
			)
		displayFolder: _KPI
		lineageTag: 31c0c474-df1c-4842-af88-7123284c21c9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure RMSE = ```
			
			SQRT(
			    AVERAGEX(
			        dashboard_dataset,
			        dashboard_dataset[residual] * dashboard_dataset[residual]
			    )
			)
			
			```
		displayFolder: _Forecast accuracy
		lineageTag: e29db392-b4b0-4254-aa6a-2532706f1dd4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Inventory Risk' =
			
			IF(
			AVERAGE(dashboard_dataset[residual]) > 20,
			"HIGH",
			"LOW"
			)
		displayFolder: _Inventory
		lineageTag: 944d60c8-8fa6-4017-8ba6-fe639cd016ce

	measure 'Promotion Revenue' = ```
			
			CALCULATE(
			    SUM(dashboard_dataset[actual]),
			    dashboard_dataset[onpromotion_x] > 0
			)
			
