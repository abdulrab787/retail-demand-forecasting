	measure 'Residual Category' = ```
			
			VAR R = AVERAGE(dashboard_dataset[residual])
			RETURN
			SWITCH(
			    TRUE(),
			    R > 10, "High Over‑Prediction",
			    R > 0, "Over‑Prediction",
			    R < -10, "High Under‑Prediction",
			    R < 0, "Under‑Prediction",
			    "Perfect"
			)
			
